# Copy to .env and fill in. Do NOT commit .env.
DATABASE_URL="postgresql://phobamboo:CHANGE_ME@localhost:5432/phobamboo?schema=public"

# Server
PORT=4000
# Bind address. Leave 0.0.0.0 to reach it via IP:PORT (no domain yet).
# Once behind the CloudPanel reverse proxy + SSL, set 127.0.0.1 to hide :4000
# from the internet (only the proxy can reach it).
HOST=0.0.0.0
# Comma-separated list of allowed frontend origins (CORS).
# Not needed when the backend serves the frontend on the same origin (prod).
CORS_ORIGINS="http://localhost:5173"

# Path to the built frontend (Vite dist). When set & present, backend serves the
# SPA on the same port — single-port deploy. Default: ../frontend/dist
# FRONTEND_DIR="/home/phobamboo/app/frontend/dist"

# Auth — keep this long and random in production
JWT_SECRET="CHANGE_ME_to_a_long_random_string"
JWT_EXPIRES_IN="30d"

# Default admin account created by `npm run seed` (boss wants it simple/memorable)
SEED_ADMIN_USER="admin"
SEED_ADMIN_PASS="phobamboo"

# Separate read-only account for the sales/customer big-screen (/insights)
SEED_VIEWER_USER="patron"
SEED_VIEWER_PASS="patron"

# Uploads — absolute or relative path on the VPS disk
UPLOAD_DIR="./uploads"
# Leave PUBLIC_URL empty to return relative /uploads/... links (recommended —
# survives IP→domain changes). Only set it if images are served from another host.
PUBLIC_URL=""

# Firebase migration (only needed once). Path to service account JSON.
FIREBASE_SERVICE_ACCOUNT="./firebase-service-account.json"
